rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'trishnshukla9011@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
               data.uid == userId &&
               data.email is string && data.email.size() <= 256 &&
               data.displayName is string && data.displayName.size() <= 256 &&
               data.role in ['farmer', 'consumer', 'analyst', 'admin'];
      }

      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'role']) &&
        incoming().role in ['farmer', 'consumer', 'analyst'] // Prevent self-promoting to admin
      ) || isAdmin();
    }

    // --- Crop Analysis ---
    match /crops/{cropId} {
      function isValidCrop(data) {
        return data.keys().hasAll(['userId', 'imageUrl', 'disease', 'severity', 'treatment', 'confidence', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.imageUrl is string && data.imageUrl.size() <= 1048576; // Support base64 if needed, though usually URLs
      }

      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidCrop(incoming());
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // --- Irrigation Logs ---
    match /irrigation_logs/{logId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && incoming().userId == request.auth.uid;
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isEmailVerified() && (
        (incoming().farmerId == request.auth.uid) || 
        (existing().farmerId == request.auth.uid) ||
        isAdmin()
      );
    }

    // --- System Alerts ---
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
