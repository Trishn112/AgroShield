rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn(); // Relaxing for prototype to avoid common permission errors
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'trishnshukla9011@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
               data.uid == userId &&
               data.email is string && data.email.size() <= 256 &&
               data.displayName is string && data.displayName.size() <= 256 &&
               data.role in ['farmer', 'consumer', 'analyst', 'admin'];
      }

      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'role']) &&
        incoming().role in ['farmer', 'consumer', 'analyst'] // Prevent self-promoting to admin
      ) || isAdmin();
    }

    // --- Crop Analysis ---
    match /crops/{cropId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().imageUrl.size() <= 1048576;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- Irrigation Logs ---
    match /irrigation_logs/{logId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && incoming().userId == request.auth.uid;
    }

    // --- System Alerts ---
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- User Feedback ---
    match /feedback/{feedbackId} {
      function isValidFeedback(data) {
        return data.keys().hasAll(['userId', 'userEmail', 'category', 'message', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.category in ['bug', 'feature', 'general'] &&
               data.message is string && data.message.size() <= 2000;
      }
      allow create: if isSignedIn() && isValidFeedback(incoming());
      allow read: if isAdmin();
    }

    // --- Products (Marketplace) ---
    match /products/{productId} {
      function isValidProduct(data) {
        return data.keys().hasAll(['farmerId', 'name', 'category', 'price', 'stock', 'createdAt']) &&
               data.farmerId == request.auth.uid &&
               data.category in ['Crop', 'Seed', 'Fertilizer', 'Tool'] &&
               data.price is number && data.price > 0 &&
               data.stock is number &&
               data.name is string && data.name.size() <= 256;
      }
      allow read: if true;
      allow create: if isSignedIn() && (isValidProduct(incoming()) || isAdmin());
      allow update: if isSignedIn() && (
        (existing().farmerId == request.auth.uid && incoming().farmerId == existing().farmerId) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (existing().farmerId == request.auth.uid || isAdmin());
    }

    // --- User Tasks ---
    match /tasks/{taskId} {
      function isValidTask(data) {
        return data.keys().hasAll(['userId', 'title', 'priority', 'completed', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.title is string && data.title.size() <= 256 &&
               data.priority in ['Low', 'Medium', 'High'] &&
               data.completed is bool;
      }
      
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isSignedIn() && (
        (existing().userId == request.auth.uid && incoming().userId == existing().userId) ||
        isAdmin()
      ) && (
        // Action: Complete toggle
        (incoming().diff(existing()).affectedKeys().hasOnly(['completed'])) ||
        // Action: General edit
        (incoming().diff(existing()).affectedKeys().hasAll(['title', 'priority']))
      );
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }
  }
}
